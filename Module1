import pandas as pd
from sklearn.model_selection import train_test_split
df = pd.read_csv("loan_applications.csv")
print(df['gender'].value_counts(normalize=True))
print(df['race'].value_counts(normalize=True))
df['income'].fillna(df['income'].median(), inplace=True)
train, test = train_test_split(df, test_size=0.2, stratify=df['approved'])

// Model Training & Development
from fairlearn.reductions import ExponentiatedGradient, DemographicParity
from sklearn.linear_model import LogisticRegression
sensitive_features = train['gender']
classifier = LogisticRegression()
mitigator = ExponentiatedGradient(classifier, constraints=DemographicParity())
mitigator.fit(train.drop('approved', axis=1), train['approved'], sensitive_features=sensitive_features)

//Model Evaluation & Audit
from fairlearn.metrics import demographic_parity_difference, selection_rate
y_pred = mitigator.predict(test.drop('approved', axis=1))
dp_diff = demographic_parity_difference(
    test['approved'], y_pred, sensitive_features=test['gender']
)
print(f"Demographic Parity Difference: {dp_diff:.4f}")

