def check_copyright_compliance(generated_code):
    copyright_keywords = ["proprietary", "copyright", "all rights reserved"]
    for word in copyright_keywords:
        if word in generated_code.lower():
            return "Potential copyright infringement detected."
    return "No obvious infringement detected. Proceed with caution."
